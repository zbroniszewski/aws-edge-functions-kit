{
  "scripts": {
    "build": "rimraf ./dist && tsc --project tsconfig.build.json && npm run bundle",
    "bundle": "rollup -c && sed -i '/exports/d' ./dist/cloudfront/viewer-request/index.js",
    "deploy": "ts-node --files deploy.ts",
    "deploy2": "ts-node --files deploy-2.ts",
    "lint": "eslint --cache --ext .json,.js,.ts .",
    "lint:fix": "eslint --fix --cache --ext .json,.js,.ts .",
    "prepare": "husky install",
    "pre-commit": "lint-staged",
    "test": "jest --verbose"
  },
  "devDependencies": {
    "@babel/core": "^7.18.6",
    "@babel/preset-env": "^7.18.6",
    "@babel/preset-typescript": "^7.28.5",
    "@rollup/plugin-commonjs": "^22.0.2",
    "@types/adm-zip": "^0.5.0",
    "@types/aws-lambda": "^8.10.101",
    "@types/bunyan": "^1.8.8",
    "@types/jest": "^28.1.5",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^18.0.4",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^5.39.0",
    "@typescript-eslint/parser": "^5.39.0",
    "babel-jest": "^28.1.3",
    "eslint": "^8.24.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-prettier": "^4.2.1",
    "husky": "^8.0.1",
    "jest": "^28.1.3",
    "lint-staged": "^13.0.3",
    "prettier": "^2.7.1",
    "rimraf": "^3.0.2",
    "rollup": "^2.79.1",
    "ts-jest": "^28.0.6",
    "ts-node": "^10.9.1"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.183.0",
    "@aws-sdk/client-lambda": "^3.183.0",
    "adm-zip": "^0.5.9",
    "bunyan": "^1.8.15",
    "js-yaml": "^4.1.0",
    "pino": "^8.6.1",
    "pino-pretty": "^9.1.1",
    "uuid": "^9.0.0"
  },
  "lint-staged": {
    "*.{json,js,ts}": "npm run lint:fix"
  }
}
